<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/pill_background"
    android:elevation="8dp"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Primary status row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:id="@+id/statusDot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/dot_grey" />

        <TextView
            android:id="@+id/statusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:text="DETECTING..."
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/scoreLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text=""
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/toggleBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="II"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Scam warning row — hidden by default -->
    <LinearLayout
        android:id="@+id/scamWarningRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="#33FF6600"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠"
            android:textColor="#FFFF6600"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/scamWarningLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:maxWidth="220dp"
            android:text="Suspicious content detected"
            android:textColor="#FFFF6600"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/scamDismissBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="✕"
            android:textColor="#CCFF6600"
            android:textSize="11sp" />

    </LinearLayout>

</LinearLayout>
